    "express-rate-limit": "^8.3.2",
    "express-session": "^1.19.0",
    "helmet": "^8.1.0",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-helmet-async": "^2.0.5",
    "react-router-dom": "^6.30.1",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@playwright/mcp": "^0.0.70",
    "@playwright/test": "^1.59.1",
