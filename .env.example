# Server Configuration
PORT=3002
NODE_ENV=production
SITE_URL=https://remodelingcontractorsc.com

# Session Security (REQUIRED - Generate with: openssl rand -base64 32)
SESSION_SECRET=your-secure-random-session-secret-change-me-in-production

# Email Configuration (SMTP)
SMTP_HOST=smtp.your-provider.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password
LEAD_FROM_EMAIL=website@remodelingcontractorsc.com

# Cloudflare Turnstile (Spam Protection)
# Get keys from: https://dash.cloudflare.com/ → Turnstile
# For testing, use visible key: 1x00000000000000000000AA (always passes)
TURNSTILE_SECRET_KEY=0x4AAA...your-secret-key-here
VITE_TURNSTILE_SITE_KEY=0x4AAA...your-site-key-here

# Notes:
# - All VITE_ prefixed variables are exposed to the frontend
# - SESSION_SECRET must be a secure random string (32+ characters)
# - Turnstile keys start with '0x' or '1x' prefix
# - Set NODE_ENV=development for local testing